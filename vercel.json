{
  "builds": [
    {
      "src": "organizational_root/wsgi.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "organizational_root/wsgi.py"
    }
  ],
  "installCommand": "uv pip install -r requirements.txt",
  "buildCommand": "cd organizational_root && python manage.py migrate --noinput"
}
