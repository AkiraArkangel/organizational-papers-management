{
  "builds": [
    {
      "src": "organizational_root/organizational_system/wsgi.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "organizational_root/organizational_system/wsgi.py"
    }
  ],
  "installCommand": "uv pip install --system -r organizational_root/requirements.txt"
}
