<!DOCTYPE html>
<html>
{% load static %}
<head>
    <title>Upload Document | OrgSys</title>
    <link rel="stylesheet" href="{% static 'css/orgsys.css' %}?v=20260524-review-polish">
    <style>
        body { --page-bg: url("{% static 'images/snsu-background.jpg' %}"); }
    </style>
</head>
<body>
    <main class="auth-page">
        <section class="auth-panel panel">
            <a class="brand" href="{% url 'dashboard' %}">
                <img class="brand-logo" src="{% static 'images/SNSU Logo (No Background).png' %}" alt="OrgSys logo">
                <span>
                    <span class="brand-name">OrgSys</span>
                    <span class="brand-subtitle">Submit organization paper in a folder</span>
                </span>
            </a>

            <h2>
                {% if resubmit_document %}
                    Upload Revised File
                {% elif existing_folder %}
                    Add File to {{ existing_folder.name }}
                {% else %}
                    Create Folder / Upload File
                {% endif %}
            </h2>

            {% if not existing_folder and not resubmit_document %}
                <p class="form-note">Name the folder the Activity Name or Report that you will be submitting.</p>
            {% endif %}

            {% if section_templates %}
                <div class="template-list compact-template-list">
                    {% for template in section_templates %}
                        <a class="file-link" href="{{ template.template_file.url }}" download>
                            {{ template.get_section_display }}: {{ template.filename }}
                        </a>
                    {% endfor %}
                </div>
            {% endif %}

            <form method="POST" enctype="multipart/form-data">
                {% csrf_token %}
                {{ form.as_p }}
                <button type="submit">
                    {% if resubmit_document %}
                        Upload Revised File
                    {% elif existing_folder %}
                        Add File
                    {% else %}
                        Create Folder and Submit File
                    {% endif %}
                </button>
                <a class="btn" href="{% url 'dashboard' %}">Cancel</a>
            </form>
        </section>
    </main>
</body>
</html>
