<!DOCTYPE html>
<html>
{% load static %}
<head>
    <title>Adviser Dashboard | OrgSys</title>
    <link rel="stylesheet" href="{% static 'css/orgsys.css' %}?v=20260524-review-polish">
    <style>
        body { --page-bg: url("{% static 'images/snsu-background.jpg' %}"); }
    </style>
</head>
<body>
    <main class="page">
        <header class="topbar">
            <a class="brand" href="{% url 'adviser_dashboard' %}">
                {% if adviser_profile.organization.logo %}
                    <img class="brand-logo" src="{{ adviser_profile.organization.logo.url }}?v={{ adviser_profile.organization.logo_updated_at|date:'U' }}" alt="{{ adviser_profile.organization.organization_name }} logo">
                {% else %}
                    <img class="brand-logo" src="{% static 'images/SNSU Logo (No Background).png' %}" alt="OrgSys logo">
                {% endif %}
                <span>
                    <span class="brand-name">{{ adviser_profile.organization.organization_name }} ({{ adviser_profile.organization.user.username }})</span>
                    <span class="brand-subtitle">Adviser Account</span>
                </span>
            </a>

            <div class="actions">
                <a class="btn" href="{% url 'home' %}">Home</a>
                <form method="POST" action="{% url 'delete_account' %}" class="action-form">
                    {% csrf_token %}
                    <button type="submit" class="danger-btn" onclick="return confirm('Delete this adviser account?');">Delete Account</button>
                </form>
                <form method="POST" action="{% url 'logout' %}" class="action-form">
                    {% csrf_token %}
                    <button type="submit">Logout</button>
                </form>
            </div>
        </header>

        {% include 'documents/_messages.html' %}

        {% if latest_notification %}
            <div class="toast-notification panel" role="status" aria-live="polite">
                <strong>New File Submitted</strong>
                <span>{{ latest_notification.user.username }}</span>
            </div>
        {% endif %}

        {% include 'documents/_template_drawer.html' %}

        <section id="file-submissions" class="tab-panel table-panel panel file-submissions-panel is-active" data-tab-panel="file-submissions">
            {% for group in section_groups %}
                {% include 'documents/_folder_section.html' with dashboard_role='adviser' %}
            {% endfor %}

            {% include 'documents/_signed_copies_panel.html' with can_upload_signed_copy=False show_signed_copy_organization=False %}
        </section>

        <section id="organization-overview" class="tab-panel" data-tab-panel="organization-overview">
            {% include 'documents/_organization_overview_panel.html' %}
        </section>
    </main>
    <nav class="bottom-tabs" aria-label="Dashboard tabs">
        <a class="bottom-tab is-active" href="#file-submissions" data-tab-target="file-submissions">File Submissions</a>
        <a class="bottom-tab" href="#organization-overview" data-tab-target="organization-overview">Organization Overview</a>
    </nav>
    <script src="{% static 'js/toast-dismiss.js' %}"></script>
    <script src="{% static 'js/tab-switch.js' %}?v=20260513-polished-tabs"></script>
</body>
</html>
