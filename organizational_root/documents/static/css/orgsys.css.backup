:root {
    --bg-overlay-top: rgba(16, 86, 72, 0.84);
    --bg-overlay-bottom: rgba(14, 62, 92, 0.86);
    --panel: rgba(8, 42, 39, 0.78);
    --panel-strong: rgba(3, 28, 31, 0.86);
    --line: rgba(255, 255, 255, 0.16);
    --text: #f7fbf9;
    --muted: #cde4dc;
    --field: #e9f4f1;
    --primary: #0d47a1;
    --primary-hover: #1565c0;
    --danger: #b71c1c;
    --danger-hover: #d32f2f;
}

* {
    box-sizing: border-box;
}

body {
    margin: 0;
    min-height: 100vh;
    padding-bottom: 82px;
    font-family: "Segoe UI", Arial, sans-serif;
    color: var(--text);
    position: relative;
}

body::before {
    content: "";
    position: fixed;
    inset: 0;
    background: var(--page-bg) no-repeat center center/cover;
    opacity: 0.62;
    z-index: -2;
}

body::after {
    content: "";
    position: fixed;
    inset: 0;
    background: linear-gradient(var(--bg-overlay-top), var(--bg-overlay-bottom));
    z-index: -1;
}

a {
    color: #d7f2df;
    font-weight: bold;
    text-decoration: none;
}

.page {
    width: min(1320px, 96vw);
    margin: 0 auto;
    padding: 24px 0 40px;
}

.topbar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 18px;
    margin-bottom: 22px;
}

.brand {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    color: var(--text);
}

.brand-logo {
    width: 48px;
    height: 48px;
    border-radius: 8px;
    object-fit: contain;
    background: rgba(255, 255, 255, 0.16);
    border: 1px solid var(--line);
    padding: 4px;
}

.brand-name {
    display: block;
    max-width: min(520px, 58vw);
    overflow-wrap: anywhere;
    font-size: 23px;
    font-weight: 800;
    line-height: 1.08;
}

.brand-subtitle {
    color: var(--muted);
    display: block;
    font-size: 12px;
    font-weight: 500;
    margin-top: 4px;
}

.actions,
.header-actions {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 10px;
    justify-content: flex-end;
}

.actions .action-form,
.header-actions .action-form {
    display: flex;
}

.actions .btn,
.actions button,
.header-actions .btn,
.header-actions button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 40px;
    margin-top: 0;
}

.panel {
    background: var(--panel);
    border: 1px solid var(--line);
    border-radius: 8px;
    box-shadow: 0 18px 45px rgba(0, 0, 0, 0.28);
    backdrop-filter: blur(10px);
}

.auth-page {
    min-height: 100vh;
    display: grid;
    place-items: center;
    padding: 24px;
}

.auth-panel {
    width: min(430px, 94vw);
    padding: 28px;
}

.auth-form {
    display: grid;
    gap: 2px;
}

.auth-actions {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 10px;
    margin-top: 8px;
}

.auth-actions .btn,
.auth-actions button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    min-height: 42px;
    margin-top: 0;
}

.review-panel {
    width: min(880px, 96vw);
}

.home-panel {
    width: min(360px, 88vw);
    margin: 80px auto 0;
    padding: 24px 20px;
    text-align: center;
}

.home-panel .brand {
    justify-content: center;
    width: 100%;
}

.home-panel .brand-name {
    font-size: 22px;
}

.home-panel .brand-subtitle {
    max-width: 210px;
    line-height: 1.3;
}

.table-panel {
    overflow-x: auto;
}

.section-heading {
    margin: 0;
    padding: 9px 13px;
    border: 1px solid rgba(255, 255, 255, 0.2);
    border-left: 5px solid #d7f2df;
    border-radius: 6px;
    background: rgba(2, 24, 27, 0.48);
    box-shadow:
        inset 0 1px 0 rgba(255, 255, 255, 0.12),
        0 8px 18px rgba(0, 0, 0, 0.12);
    color: #ffffff;
    font-family: "Segoe UI Semibold", "Segoe UI", Arial, sans-serif;
    font-size: 17px;
    font-weight: 700;
    letter-spacing: 0;
    text-transform: none;
}

.file-submissions-panel {
    display: grid;
    gap: 16px;
    padding: 16px;
    animation: tab-content-in 0.24s ease-out;
}

.file-section {
    position: relative;
    overflow: hidden;
    border: 2px solid rgba(215, 242, 223, 0.36);
    border-radius: 8px;
    background: rgba(255, 255, 255, 0.065);
    box-shadow:
        inset 0 1px 0 rgba(255, 255, 255, 0.1),
        0 10px 26px rgba(0, 0, 0, 0.16);
}

.file-section::before {
    content: "";
    position: absolute;
    inset: 0 auto 0 0;
    width: 8px;
    background: linear-gradient(180deg, #d7f2df, #1565c0);
}

.file-section::after {
    content: none;
    display: none;
}

.file-section-header,
.organizations-heading {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    padding: 18px 18px 14px 22px;
    background: linear-gradient(90deg, rgba(2, 24, 27, 0.88), rgba(28, 70, 88, 0.54));
    border-bottom: 1px solid rgba(215, 242, 223, 0.34);
}

.section-meta {
    display: inline-flex;
    align-items: center;
    min-height: 28px;
    padding: 5px 9px;
    border: 1px solid rgba(215, 242, 223, 0.55);
    border-radius: 7px;
    background: rgba(2, 24, 27, 0.66);
    color: #ffffff;
    font-size: 11px;
    font-weight: 800;
    text-transform: uppercase;
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.08);
}

.section-note,
.form-note {
    margin: 8px 0 0;
    color: var(--muted);
    font-size: 13px;
    font-weight: 800;
    line-height: 1.4;
}

.folder-list {
    display: grid;
    gap: 12px;
    padding: 14px;
}

.submission-folder {
    overflow: hidden;
    border: 1px solid rgba(215, 242, 223, 0.28);
    border-radius: 8px;
    background: rgba(2, 24, 27, 0.28);
}

.folder-summary {
    display: grid;
    grid-template-columns: minmax(180px, 1fr) minmax(180px, 0.8fr) auto;
    gap: 12px;
    align-items: center;
    min-height: 58px;
    padding: 12px 14px;
    cursor: pointer;
    list-style: none;
    background: rgba(2, 24, 27, 0.42);
}

.folder-summary::-webkit-details-marker {
    display: none;
}

.submission-folder[open] .folder-title {
    color: #ffffff;
}

.submission-folder[open] .folder-title::first-letter {
    color: #d7f2df;
}

.folder-title,
.folder-organization {
    overflow-wrap: anywhere;
}

.folder-title {
    color: #d7f2df;
    font-size: 16px;
    font-weight: 900;
}

.folder-organization {
    color: var(--muted);
    font-size: 13px;
    font-weight: 800;
}

.folder-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    align-items: center;
    padding: 10px 14px;
    border-top: 1px solid rgba(255, 255, 255, 0.1);
}

.submission-folder table {
    min-width: 980px;
    border-width: 1px 0 0;
}

.signed-copies-panel {
    overflow-x: auto;
}

.signed-copy-form {
    display: grid;
    gap: 6px;
    padding: 16px;
    border-bottom: 1px solid rgba(215, 242, 223, 0.18);
}

.signed-copy-form p {
    margin: 0;
}

.signed-copy-form button {
    justify-self: start;
}

.template-drawer {
    position: fixed;
    top: 116px;
    right: 0;
    z-index: 6;
    display: grid;
    pointer-events: none;
}

.template-drawer-toggle {
    position: absolute;
    width: 1px;
    height: 1px;
    opacity: 0;
}

.template-drawer-button {
    pointer-events: auto;
    position: absolute;
    right: 0;
    top: 24px;
    display: grid;
    place-items: center;
    width: 34px;
    height: 58px;
    margin: 0;
    border: 1px solid rgba(215, 242, 223, 0.32);
    border-right: 0;
    border-radius: 8px 0 0 8px;
    background: rgba(2, 24, 27, 0.9);
    color: #ffffff;
    cursor: pointer;
    font-size: 28px;
    font-weight: 900;
    line-height: 1;
}

.template-drawer-panel {
    pointer-events: auto;
    display: grid;
    gap: 12px;
    width: min(340px, calc(100vw - 48px));
    max-height: min(620px, calc(100vh - 150px));
    overflow-y: auto;
    padding: 16px;
    border: 1px solid rgba(215, 242, 223, 0.28);
    border-right: 0;
    border-radius: 8px 0 0 8px;
    background: rgba(2, 24, 27, 0.94);
    box-shadow: 0 18px 44px rgba(0, 0, 0, 0.32);
    transform: translateX(100%);
    transition: transform 0.22s ease;
}

.template-drawer-toggle:checked ~ .template-drawer-panel {
    transform: translateX(0);
}

.template-drawer-toggle:checked ~ .template-drawer-button {
    transform: translateX(calc(-1 * min(340px, calc(100vw - 48px))));
}

.template-drawer-panel h2 {
    margin: 0;
    font-size: 18px;
}

.template-drawer-section {
    display: grid;
    gap: 8px;
    padding: 10px;
    border: 1px solid rgba(255, 255, 255, 0.14);
    border-radius: 8px;
    background: rgba(255, 255, 255, 0.06);
}

.template-drawer-section h3 {
    margin: 0;
    color: #ffffff;
    font-size: 13px;
}

.template-drawer-files,
.template-file-list {
    display: grid;
    gap: 8px;
    min-width: 0;
}

.template-list {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    align-items: center;
}

.compact-template-list {
    margin-bottom: 16px;
}

.section-template-slot {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    align-items: center;
    padding: 14px 16px;
    border-bottom: 1px solid rgba(215, 242, 223, 0.16);
    background: rgba(2, 24, 27, 0.18);
}

.template-format-card {
    display: grid;
    gap: 10px;
    min-width: min(360px, 100%);
    padding: 12px 14px;
    border: 1px solid rgba(215, 242, 223, 0.42);
    border-left: 6px solid #4caf50;
    border-radius: 8px;
    background: linear-gradient(90deg, rgba(76, 175, 80, 0.18), rgba(255, 255, 255, 0.08));
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.1);
}

.template-format-kicker {
    color: #ffffff;
    font-size: 11px;
    font-weight: 900;
    text-transform: uppercase;
}

.template-format-link {
    justify-self: start;
    max-width: 100%;
    background: rgba(2, 24, 27, 0.34);
    border: 1px solid rgba(255, 255, 255, 0.14);
}

.template-file-wrap {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    align-items: center;
    min-width: 0;
}

.template-change-form {
    display: inline-flex;
    margin: 0;
}

.template-change-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 30px;
    padding: 7px 10px;
    margin: 0;
    border: 1px solid rgba(255, 255, 255, 0.22);
    border-radius: 6px;
    background: rgba(13, 71, 161, 0.78);
    color: #ffffff;
    cursor: pointer;
    font-size: 12px;
    font-weight: 900;
    opacity: 1;
    transform: none;
    transition: opacity 0.18s ease, transform 0.18s ease, background 0.18s ease;
}

.template-file-wrap:hover .template-change-btn,
.template-change-btn:focus-within {
    opacity: 1;
    transform: translateY(0);
}

.template-change-btn:hover {
    background: var(--primary-hover);
}

.template-change-btn input,
.hidden-submit {
    position: absolute;
    width: 1px;
    height: 1px;
    opacity: 0;
    pointer-events: none;
}

.template-format-empty {
    color: var(--muted);
    font-size: 13px;
    font-weight: 800;
}

.template-empty-form,
.template-replace-form {
    display: grid;
    gap: 12px;
    align-items: center;
}

.template-empty-form {
    grid-template-columns: minmax(220px, 1fr) auto;
    width: min(620px, 100%);
}

.template-replace-form {
    grid-template-columns: minmax(200px, 1fr) auto;
    width: min(460px, 100%);
}

.template-empty-form input,
.template-replace-form input {
    margin-top: 0;
}

.template-empty-form button,
.template-replace-form button {
    margin-top: 0;
    white-space: nowrap;
}

input[type="file"] {
    border: 1px solid rgba(215, 242, 223, 0.32);
    background: rgba(2, 24, 27, 0.48);
    color: var(--text);
    box-shadow:
        inset 0 1px 0 rgba(255, 255, 255, 0.08),
        0 8px 18px rgba(0, 0, 0, 0.12);
}

input[type="file"]::file-selector-button {
    margin: -2px 10px -2px -2px;
    padding: 8px 11px;
    border: 0;
    border-radius: 5px;
    background: rgba(215, 242, 223, 0.92);
    color: #082a27;
    cursor: pointer;
    font: inherit;
    font-weight: 800;
}

.template-upload-form p {
    margin: 0;
}

.toast-notification {
    position: fixed;
    top: 22px;
    right: 22px;
    z-index: 5;
    display: grid;
    gap: 4px;
    width: min(280px, calc(100vw - 44px));
    padding: 14px 16px;
    text-align: left;
    animation: toast-in 0.28s ease-out;
    cursor: grab;
    touch-action: pan-y;
    user-select: none;
    will-change: transform, opacity;
    transition: transform 0.22s ease, opacity 0.22s ease;
}

.toast-notification.is-dragging {
    cursor: grabbing;
    transition: none;
}

.toast-notification.is-dismissing {
    opacity: 0;
    pointer-events: none;
    transform: translateX(var(--dismiss-x, calc(100% + 32px)));
}

.toast-notification span {
    color: var(--muted);
}

@keyframes toast-in {
    from {
        opacity: 0;
        transform: translateY(-8px);
    }
    to {
        opacity: 1;
        transform: translateY(0);
    }
}

h1,
h2 {
    margin: 0 0 18px;
}

p {
    margin: 0 0 14px;
}

label {
    display: block;
    margin-top: 12px;
    font-weight: bold;
    color: var(--text);
}

input,
select,
button {
    width: 100%;
    padding: 10px 11px;
    margin-top: 6px;
    border: 0;
    border-radius: 6px;
    font: inherit;
}

input,
select,
textarea {
    background: var(--field);
    color: #102321;
}

textarea {
    width: 100%;
    min-height: 360px;
    padding: 12px;
    margin-top: 6px;
    border: 0;
    border-radius: 6px;
    font: inherit;
    line-height: 1.45;
    resize: vertical;
}

.btn,
button {
    display: inline-block;
    width: auto;
    padding: 10px 14px;
    background: var(--primary);
    color: white;
    border: 0;
    border-radius: 6px;
    cursor: pointer;
    font-weight: bold;
    text-align: center;
    transition: background 0.2s ease, transform 0.2s ease, box-shadow 0.2s ease;
}

.btn:disabled,
button:disabled {
    cursor: not-allowed;
    opacity: 0.45;
    transform: none;
    box-shadow: none;
}

.btn:hover,
button:not(:disabled):hover {
    background: var(--primary-hover);
    transform: translateY(-1px);
    box-shadow: 0 8px 18px rgba(0, 0, 0, 0.22);
}

.danger-btn {
    background: var(--danger);
}

.danger-btn:hover {
    background: var(--danger-hover);
}

.nav-links {
    display: grid;
    justify-items: center;
    gap: 12px;
    margin-top: 22px;
}

.home-panel .nav-links {
    width: min(200px, 100%);
    margin-left: auto;
    margin-right: auto;
}

.home-panel .btn {
    width: 100%;
}

table {
    width: 100%;
    min-width: 1080px;
    border-collapse: collapse;
    border: 1px solid rgba(255, 255, 255, 0.14);
}

th,
td {
    padding: 14px;
    text-align: center;
    vertical-align: middle;
    border: 1px solid rgba(255, 255, 255, 0.1);
}

th {
    background: var(--panel-strong);
    color: #eaf7f2;
    font-size: 13px;
    font-weight: 800;
    text-transform: uppercase;
    box-shadow: inset 0 -1px 0 rgba(215, 242, 223, 0.22);
}

tr:nth-child(even) {
    background: rgba(255, 255, 255, 0.05);
}

.status {
    display: inline-block;
    min-width: 110px;
    max-width: 240px;
    padding: 7px 12px;
    border-radius: 999px;
    font-size: 12px;
    font-weight: bold;
}

.status-stack,
.stacked-actions {
    display: grid;
    justify-items: center;
    gap: 7px;
}

.SUBMITTED,
.submitted {
    background: #ff9800;
}

.CORRECTED,
.corrected,
.status[class*="corrected-by"] {
    background: #2196f3;
}

.RESUBMITTED,
.resubmitted {
    background: #9c27b0;
}

.READY_FOR_PRINTING,
.ready-for-printing,
.approved-by-adviser,
.success-btn {
    background: #4caf50;
}

.REGISTERED,
.registered,
.pending-adviser-review {
    background: #607d8b;
}

.status[class*="approved-by"] {
    background: #2e7d32;
}

.status[class*="forwarded-by"] {
    background: #00838f;
}

.success-btn:hover {
    background: #43a047;
}

.muted-text {
    color: var(--muted);
    font-size: 12px;
    font-weight: bold;
}

.folder-forward-form {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    align-items: end;
    margin: 0;
}

.folder-forward-form label {
    display: grid;
    gap: 4px;
    min-width: 180px;
    margin: 0;
    color: var(--muted);
    font-size: 11px;
    font-weight: 900;
    text-transform: uppercase;
}

.folder-forward-form select,
.folder-forward-form button {
    margin-top: 0;
}

.forwarding-note {
    max-width: 520px;
    color: var(--muted);
    font-size: 12px;
    font-weight: 700;
    line-height: 1.35;
}

.empty-state {
    padding: 22px;
    text-align: center;
    color: var(--muted);
}

.file-link {
    display: inline-block;
    padding: 7px 10px;
    border-radius: 6px;
    max-width: min(440px, 100%);
    overflow-wrap: anywhere;
    transition: background 0.2s ease, color 0.2s ease, transform 0.2s ease, box-shadow 0.2s ease;
}

.current-file-column,
.current-file-cell {
    min-width: 260px;
    width: 30%;
}

.current-file-cell .file-link {
    width: 100%;
}

.file-link:hover {
    background: rgba(215, 242, 223, 0.18);
    color: #ffffff;
    transform: translateY(-2px);
    box-shadow: 0 6px 14px rgba(0, 0, 0, 0.25);
}

.file-link::after {
    content: " download";
    font-size: 11px;
    opacity: 0;
    margin-left: 6px;
    transition: opacity 0.2s ease;
}

.file-link:hover::after {
    opacity: 1;
}

.preview-link::after {
    content: " view";
}

.file-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin: 0 0 18px;
}

.review-layout {
    display: grid;
    grid-template-columns: 1fr;
    gap: 16px;
    align-items: start;
}

.pdf-review,
.correction-form {
    min-width: 0;
}

.review-layout-no-preview {
    grid-template-columns: 1fr;
}

.document-review-card {
    display: grid;
    gap: 12px;
    min-width: 0;
    padding: 16px;
    border: 1px solid rgba(215, 242, 223, 0.26);
    border-radius: 8px;
    background: rgba(255, 255, 255, 0.08);
    align-self: start;
}

.document-summary-card {
    margin-bottom: 16px;
    background: rgba(2, 24, 27, 0.32);
}

.review-page-heading {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    margin: 20px 0 16px;
}

.review-page-heading h2 {
    margin: 0;
}

.document-meta-grid {
    display: grid;
    grid-template-columns: 130px minmax(0, 1fr);
    gap: 10px 14px;
    align-items: start;
}

.document-meta-grid span {
    color: var(--muted);
    font-size: 12px;
    font-weight: 900;
    text-transform: uppercase;
}

.document-meta-grid strong {
    font-size: 15px;
}

.document-review-card strong {
    color: #ffffff;
    font-size: 18px;
    line-height: 1.25;
    overflow-wrap: anywhere;
}

.document-review-card p {
    margin: 0;
    color: var(--muted);
    line-height: 1.45;
}

.document-review-kicker {
    color: var(--muted);
    font-size: 11px;
    font-weight: 900;
    text-transform: uppercase;
}

.document-review-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    padding-top: 4px;
}

.document-review-actions .btn,
.document-review-actions button {
    margin-top: 0;
}

.review-panel .correction-form {
    display: grid;
    gap: 12px;
    padding: 16px;
    border: 1px solid rgba(215, 242, 223, 0.26);
    border-radius: 8px;
    background: rgba(2, 24, 27, 0.24);
}

.review-panel .correction-form p {
    margin: 0;
}

.review-panel .correction-notes {
    min-height: 240px;
}

.pdf-frame {
    width: 100%;
    height: min(72vh, 760px);
    min-height: 520px;
    border: 1px solid var(--line);
    border-radius: 6px;
    background: #ffffff;
}

.correction-summary {
    display: inline-block;
    max-width: 220px;
    text-align: left;
    overflow-wrap: anywhere;
}

.admin-checklist-summary {
    display: grid;
    gap: 8px;
    max-width: 260px;
    margin: 0 auto;
    padding-left: 20px;
    text-align: left;
}

.admin-checklist-summary li {
    padding: 0 0 8px 4px;
    border-bottom: 1px solid rgba(255, 255, 255, 0.14);
    line-height: 1.35;
    overflow-wrap: anywhere;
}

.admin-checklist-summary li:last-child {
    border-bottom: 0;
    padding-bottom: 0;
}

.form-section-heading {
    display: grid;
    gap: 4px;
    margin: 0 0 10px;
}

.form-section-heading h3 {
    margin: 0;
    font-size: 18px;
}

.form-section-heading p,
.checklist-heading span {
    margin: 0;
    color: var(--muted);
    font-size: 13px;
    line-height: 1.4;
}

.ready-section {
    margin-top: 18px;
}

.live-checklist-preview {
    display: grid;
    gap: 10px;
    margin: 0 0 18px;
    padding: 12px;
    border: 1px solid var(--line);
    border-radius: 6px;
    background: rgba(255, 255, 255, 0.08);
}

.live-checklist-preview.is-empty .live-checklist-items {
    display: none;
}

.live-checklist-items {
    display: grid;
    gap: 8px;
}

.preview-checklist-item {
    padding: 8px;
    border-radius: 6px;
    background: rgba(255, 255, 255, 0.08);
}

.checklist-form {
    display: grid;
    gap: 10px;
    min-width: 220px;
    text-align: left;
}

.checklist-readonly {
    display: grid;
    gap: 9px;
    max-width: 300px;
    margin: 0 auto;
    text-align: left;
}

.checklist-readonly span {
    color: var(--muted);
    font-size: 12px;
    line-height: 1.35;
}

.checklist-heading {
    display: grid;
    gap: 3px;
}

.checklist-item {
    display: grid;
    grid-template-columns: 22px minmax(0, 1fr);
    align-items: start;
    gap: 8px;
    margin: 0;
    color: var(--text);
    font-weight: 500;
    line-height: 1.35;
}

.checklist-item input {
    width: 20px;
    height: 20px;
    margin: 0;
    padding: 0;
    accent-color: #4caf50;
    cursor: pointer;
}

.checklist-choice {
    padding: 8px;
    border: 1px solid rgba(215, 242, 223, 0.32);
    border-radius: 6px;
    background: rgba(255, 255, 255, 0.08);
}

.checklist-choice span {
    padding-top: 1px;
}

.ready-checkbox {
    margin: 0 0 14px;
}

.small-btn {
    padding: 7px 10px;
    font-size: 12px;
}

.action-form {
    margin: 0;
}

.helptext {
    color: var(--muted);
    display: block;
    font-size: 12px;
    margin-top: 4px;
}

.errorlist {
    color: #ffd7d7;
    padding-left: 18px;
}

.message-stack {
    display: grid;
    gap: 8px;
    margin: 0 0 16px;
}

.message {
    padding: 10px 12px;
    border: 1px solid rgba(215, 242, 223, 0.28);
    border-radius: 6px;
    background: rgba(2, 24, 27, 0.7);
    color: #ffffff;
    font-weight: 800;
}

.message-error {
    border-color: rgba(255, 215, 215, 0.5);
    background: rgba(183, 28, 28, 0.72);
}

.hidden {
    display: none;
}

.current-file {
    display: grid;
    justify-items: center;
    gap: 6px;
}

.tab-panel:not(.is-active) {
    display: none !important;
}

.tab-panel.is-active {
    animation: tab-content-in 0.24s ease-out;
}

.tab-panel.is-active.file-submissions-panel {
    display: grid;
}

.bottom-tabs {
    position: fixed;
    left: 50%;
    bottom: 18px;
    z-index: 4;
    display: flex;
    gap: 6px;
    width: min(680px, calc(100vw - 28px));
    padding: 6px;
    transform: translateX(-50%);
    border: 1px solid rgba(215, 242, 223, 0.22);
    border-radius: 999px;
    background: rgba(2, 24, 27, 0.86);
    box-shadow: 0 14px 34px rgba(0, 0, 0, 0.34);
    backdrop-filter: blur(12px);
    animation: tabs-in 0.22s ease-out;
}

.bottom-tab {
    position: relative;
    overflow: hidden;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex: 1 1 0;
    min-height: 44px;
    padding: 10px 14px;
    border: 1px solid transparent;
    border-radius: 999px;
    color: rgba(247, 251, 249, 0.76);
    font-size: 13px;
    font-weight: 800;
    text-align: center;
    background: transparent;
    transition: background 0.2s ease, border-color 0.2s ease, color 0.2s ease, transform 0.2s ease, box-shadow 0.2s ease;
}

.bottom-tab:nth-child(1) {
    border-color: transparent;
    background: transparent;
}

.bottom-tab:nth-child(2) {
    border-color: transparent;
    background: transparent;
}

.bottom-tab::before {
    content: none;
    display: none;
}

.bottom-tab:nth-child(1)::before {
    content: none;
}

.bottom-tab:nth-child(2)::before {
    content: none;
}

.bottom-tab::after {
    content: "";
    position: absolute;
    left: 16px;
    right: 16px;
    bottom: 7px;
    height: 3px;
    border-radius: 999px;
    background: #ffffff;
    opacity: 0;
    transform: scaleX(0.35);
    transition: opacity 0.18s ease, transform 0.18s ease;
}

.bottom-tab:hover,
.bottom-tab.is-active {
    border-color: rgba(215, 242, 223, 0.28);
    background: rgba(255, 255, 255, 0.1);
    color: #ffffff;
}

.bottom-tab:hover {
    transform: translateY(-1px);
    box-shadow: 0 8px 20px rgba(0, 0, 0, 0.22);
}

.bottom-tab.is-active {
    animation: tab-switch 0.28s ease-out;
    border-color: rgba(255, 255, 255, 0.24);
    background: linear-gradient(180deg, rgba(247, 251, 249, 0.95), rgba(205, 228, 220, 0.88));
    color: #082a27;
    box-shadow:
        inset 0 1px 0 rgba(255, 255, 255, 0.72),
        0 8px 20px rgba(0, 0, 0, 0.22);
}

.bottom-tab:nth-child(1).is-active {
    border-color: rgba(255, 255, 255, 0.24);
    background: linear-gradient(180deg, rgba(247, 251, 249, 0.95), rgba(205, 228, 220, 0.88));
}

.bottom-tab:nth-child(2).is-active {
    border-color: rgba(255, 255, 255, 0.24);
    background: linear-gradient(180deg, rgba(247, 251, 249, 0.95), rgba(205, 228, 220, 0.88));
}

.bottom-tabs.is-switching .bottom-tab {
    pointer-events: none;
}

.bottom-tab.is-leaving {
    animation: tab-leave 0.16s ease-in forwards;
}

.bottom-tab.is-entering {
    animation: tab-enter 0.18s ease-out forwards;
}

.bottom-tab.is-active::after {
    opacity: 1;
    transform: scaleX(1);
}

@keyframes tabs-in {
    from {
        opacity: 0;
        transform: translate(-50%, 8px);
    }
    to {
        opacity: 1;
        transform: translate(-50%, 0);
    }
}

@keyframes tab-switch {
    0% {
        transform: translateY(4px) scale(0.98);
    }
    100% {
        transform: translateY(0) scale(1);
    }
}

@keyframes tab-content-in {
    from {
        opacity: 0;
        transform: translateY(8px);
    }
    to {
        opacity: 1;
        transform: translateY(0);
    }
}

@keyframes tab-leave {
    from {
        transform: translateY(0) scale(1);
        opacity: 1;
    }
    to {
        transform: translateY(3px) scale(0.98);
        opacity: 0.72;
    }
}

@keyframes tab-enter {
    from {
        transform: translateY(5px) scale(0.98);
    }
    to {
        transform: translateY(0) scale(1);
    }
}

.overview-layout {
    display: grid;
    grid-template-columns: minmax(0, 1fr);
    gap: 18px;
    align-items: start;
    animation: tab-content-in 0.24s ease-out;
}

.overview-panel {
    padding: 20px;
}

.organization-profile-panel {
    border-color: rgba(255, 255, 255, 0.22);
}

.officer-editor-panel {
    border-color: rgba(215, 242, 223, 0.24);
}

.overview-heading {
    display: flex;
    justify-content: space-between;
    align-items: start;
    gap: 18px;
    margin-bottom: 18px;
    padding-bottom: 16px;
    border-bottom: 1px solid rgba(255, 255, 255, 0.16);
}

.organization-identity {
    display: flex;
    align-items: center;
    gap: 14px;
    min-width: 0;
}

.organization-logo-frame {
    display: grid;
    place-items: center;
    position: relative;
    flex: 0 0 auto;
    width: 84px;
    height: 84px;
    overflow: hidden;
    border: 1px solid rgba(215, 242, 223, 0.32);
    border-radius: 8px;
    background: rgba(2, 24, 27, 0.4);
    color: var(--muted);
    font-size: 11px;
    font-weight: 900;
    text-transform: uppercase;
}

.organization-logo-frame .photo-update-form {
    inset: auto 8px 8px;
    grid-template-columns: 1fr auto;
}

.organization-logo-frame.is-empty .photo-update-form,
.organization-logo-frame:hover .photo-update-form,
.organization-logo-frame .photo-update-form:focus-within {
    opacity: 1;
    transform: translateY(0);
}

.organization-logo-frame img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    padding: 6px;
    background: rgba(255, 255, 255, 0.88);
}

.organization-logo-frame.is-empty {
    border-style: dashed;
}

.logo-upload-form {
    display: grid;
    grid-template-columns: minmax(220px, 1fr) auto;
    gap: 10px;
    align-items: end;
    margin: 0 0 18px;
    padding: 12px;
    border: 1px solid rgba(255, 255, 255, 0.18);
    border-radius: 8px;
    background: rgba(2, 24, 27, 0.24);
}

.logo-upload-form p {
    margin: 0;
}

.logo-upload-form label {
    margin-top: 0;
}

.logo-upload-form button {
    margin-top: 0;
    white-space: nowrap;
}

.overview-heading h1,
.organizations-heading h1 {
    margin: 0;
    font-size: 26px;
}

.overview-heading p {
    color: var(--muted);
    font-weight: 700;
}

.overview-count {
    flex: 0 0 auto;
    padding: 8px 11px;
    border: 1px solid rgba(255, 255, 255, 0.18);
    border-radius: 8px;
    background: rgba(255, 255, 255, 0.08);
    color: #ffffff;
    font-size: 12px;
    font-weight: 800;
}

.officer-list,
.organization-list,
.officer-form {
    display: grid;
    gap: 12px;
}

.officer-row,
.organization-card {
    display: grid;
    grid-template-columns: 42px minmax(0, 1fr) auto;
    gap: 12px;
    align-items: center;
    padding: 10px;
    border: 1px solid rgba(255, 255, 255, 0.24);
    border-radius: 8px;
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.1), rgba(255, 255, 255, 0.06));
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.08);
}

.officer-row {
    grid-template-columns: 140px minmax(0, 1fr);
    align-items: stretch;
    gap: 16px;
}

.officer-photo {
    display: grid;
    place-items: center;
    position: relative;
    width: 140px;
    height: 140px;
    overflow: hidden;
    border: 1px solid rgba(215, 242, 223, 0.3);
    border-radius: 6px;
    background: rgba(2, 24, 27, 0.36);
    color: #ffffff;
    font-size: 10px;
    font-weight: 800;
    line-height: 1.1;
    text-align: center;
    text-transform: uppercase;
}

.officer-photo.is-empty::before {
    content: "";
    width: 36px;
    height: 36px;
    border: 2px solid rgba(215, 242, 223, 0.52);
    border-radius: 50%;
    box-shadow:
        0 25px 0 -5px rgba(215, 242, 223, 0.42),
        0 0 0 12px rgba(255, 255, 255, 0.05);
}

.officer-photo img {
    width: 100%;
    height: 100%;
    object-fit: cover;
}

.officer-details {
    display: grid;
    grid-template-columns: minmax(120px, 0.55fr) auto minmax(150px, 1fr);
    gap: 8px;
    align-items: start;
    min-width: 0;
    overflow-wrap: anywhere;
}

.officer-details-form {
    display: grid;
    gap: 8px;
    align-content: space-between;
    min-width: 0;
    margin: 0;
}

.officer-field {
    display: grid;
    gap: 3px;
    min-width: 0;
    padding: 8px 10px;
    margin: 0;
    border: 1px solid rgba(255, 255, 255, 0.18);
    border-radius: 6px;
    background: rgba(2, 24, 27, 0.26);
}

.officer-field span {
    color: var(--muted);
    font-size: 10px;
    font-weight: 800;
    text-transform: uppercase;
}

.officer-field strong {
    color: #ffffff;
    font-size: 14px;
    line-height: 1.25;
}

.officer-field input {
    width: 100%;
    min-width: 0;
    padding: 8px 9px;
    margin: 0;
    border: 1px solid rgba(215, 242, 223, 0.24);
    background: rgba(233, 244, 241, 0.96);
    font-weight: 800;
}

.officer-name strong,
.officer-name input {
    font-size: 18px;
    line-height: 1.25;
}

.officer-divider {
    display: grid;
    place-items: center;
    color: var(--muted);
    font-size: 18px;
    font-weight: 800;
}

.officer-actions {
    display: flex;
    flex-wrap: wrap;
    grid-column: 2;
    justify-content: flex-start;
    align-self: end;
    gap: 8px;
    padding-top: 8px;
}

.officer-save-btn {
    justify-self: start;
    margin-top: 0;
}

.photo-update-form {
    position: absolute;
    inset: auto 8px 8px;
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 4px;
    align-items: center;
    margin: 0;
    opacity: 0;
    transform: translateY(4px);
    transition: opacity 0.18s ease, transform 0.18s ease;
}

.officer-photo.is-empty .photo-update-form,
.officer-photo:hover .photo-update-form,
.photo-update-form:focus-within {
    opacity: 1;
    transform: translateY(0);
}

.photo-update-form label {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 28px;
    padding: 6px 8px;
    margin: 0;
    border-radius: 6px;
    background: rgba(2, 24, 27, 0.82);
    color: #ffffff;
    cursor: pointer;
    font-size: 10px;
    font-weight: 900;
    text-transform: uppercase;
}

.photo-update-form input {
    position: absolute;
    width: 1px;
    height: 1px;
    opacity: 0;
    pointer-events: none;
}

.photo-save-btn {
    min-height: 28px;
    padding: 6px 8px;
    margin: 0;
    border-radius: 6px;
    font-size: 10px;
    line-height: 1;
}

.organizations-panel {
    padding: 0 0 16px;
}

.organization-list {
    padding: 16px;
}

.organization-card {
    grid-template-columns: minmax(0, 1fr) auto;
    color: var(--text);
    transition: border-color 0.2s ease, transform 0.2s ease, background 0.2s ease;
}

.organization-card:hover {
    border-color: rgba(215, 242, 223, 0.42);
    background: rgba(255, 255, 255, 0.12);
    transform: translateY(-1px);
}

.organization-card span {
    display: grid;
    gap: 4px;
}

.organization-card span span {
    color: var(--muted);
    font-size: 13px;
}

.rename-organization-form {
    display: grid;
    grid-template-columns: minmax(180px, 1fr) auto;
    gap: 8px;
    align-items: start;
    margin-top: 10px;
}

.rename-organization-form input {
    margin: 0;
}

.rename-organization-form button {
    margin: 0;
    white-space: nowrap;
}

.reviewed-forwarding-flash {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 170px;
    padding: 8px 11px;
    border-radius: 999px;
    background: #ffeb3b;
    color: #12302d;
    font-size: 12px;
    font-weight: 900;
    text-transform: uppercase;
    animation: reviewed-forwarding-pulse 1.05s ease-in-out infinite;
}

@keyframes reviewed-forwarding-pulse {
    0%,
    100% {
        opacity: 1;
        box-shadow: 0 0 0 rgba(255, 235, 59, 0);
    }
    50% {
        opacity: 0.45;
        box-shadow: 0 0 18px rgba(255, 235, 59, 0.58);
    }
}

@media (max-width: 720px) {
    .topbar {
        align-items: flex-start;
        flex-direction: column;
    }

    .actions,
    .header-actions {
        justify-content: flex-start;
    }

    .review-layout {
        grid-template-columns: 1fr;
    }

    .pdf-frame {
        min-height: 420px;
    }

    .template-empty-form,
    .template-replace-form {
        grid-template-columns: 1fr;
    }

    .file-section-header,
    .organizations-heading {
        align-items: flex-start;
        flex-direction: column;
        padding-right: 20px;
    }

    .overview-layout {
        grid-template-columns: 1fr;
    }

    .organization-identity {
        align-items: flex-start;
    }

    .organization-logo-frame {
        width: 68px;
        height: 68px;
    }

    .logo-upload-form {
        grid-template-columns: 1fr;
    }

    .officer-row {
        grid-template-columns: 112px minmax(0, 1fr);
    }

    .officer-photo {
        width: 112px;
        height: 112px;
    }

    .officer-details {
        grid-template-columns: 1fr;
    }

    .rename-organization-form {
        grid-template-columns: 1fr;
    }

    .officer-divider {
        display: none;
    }

    .officer-actions {
        grid-column: 1 / -1;
        justify-content: flex-start;
    }

    .photo-update-form {
        inset: auto 6px 6px;
        grid-template-columns: 1fr;
    }

    .bottom-tabs {
        bottom: 10px;
    }
}
